# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Anything prefixed with EXPO_PUBLIC_ is inlined into the JS bundle and is
# therefore NOT secret — only put publishable/anon keys here.

# Supabase — Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps Platform — used for Places Autocomplete, Directions, and the
# native map SDK (iOS/Android). Restrict this key by app bundle id + API in the
# Google Cloud console before shipping.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# DigiLocker OAuth client id (public). The client SECRET must NOT live here —
# it stays server-side in a Supabase Edge Function (wired in the verification phase).
EXPO_PUBLIC_DIGILOCKER_CLIENT_ID=your-digilocker-client-id
